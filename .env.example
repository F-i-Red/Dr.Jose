# Dr. José — Variáveis de Ambiente
# Copiar este ficheiro para .env e preencher os valores
# NUNCA fazer commit do ficheiro .env (já está no .gitignore)

# Chave da API OpenRouter (obter em https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-XXXXXXXXXXXXXXXXXXXXXXXX

# Modelo a utilizar via OpenRouter
# Opções recomendadas:
#   anthropic/claude-3.5-sonnet   (melhor qualidade)
#   google/gemini-flash-1.5       (mais rápido/barato)
#   meta-llama/llama-3.1-70b-instruct (open-source)
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Pasta onde estão os documentos legais
DATA_DIR=data/leis

# Pasta onde é guardada a base vetorial
CHROMA_DIR=data/chroma_db

# Nome da coleção na base vetorial
CHROMA_COLLECTION=legislacao_portuguesa

# Número de fragmentos a recuperar por pesquisa (RAG)
RAG_TOP_K=5
